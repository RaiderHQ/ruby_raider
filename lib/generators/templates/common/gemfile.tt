source 'https://rubygems.org'

gem 'activesupport'
<% if mobile? %>
gem 'appium_lib'
gem 'appium_console'
<% end %>
<%- if cucumber? -%>
gem 'allure-cucumber', '2.28.0'
<%- else -%>
gem 'allure-rspec', '2.28.0'
gem 'allure-ruby-commons', '2.28.0'
<%- end -%>
<%- if axe_addon? -%>
gem 'axe-core-rspec'
gem 'axe-core-selenium'
<%- end -%>
gem 'parallel_split_test'
gem 'parallel_tests'
gem 'rake'
gem 'reek'
<%- if rspec? -%>
gem 'rspec-retry'
<%- end -%>
gem '<%= framework %>'
<%- if cucumber? -%>
gem 'rspec'
<%- end -%>
gem 'rubocop'
<%- if rspec? -%>
gem 'rubocop-rspec'
<%- end -%>
gem 'ruby_raider', '~> 1.1.0'
<%- if selenium_based? %>
gem 'selenium-webdriver'
<%- end -%>
<%- if watir? -%>
gem 'watir'
<%- end -%>
