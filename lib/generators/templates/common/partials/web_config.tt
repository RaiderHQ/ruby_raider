browser: chrome
url: 'https://raider-test-site.onrender.com/'
timeout: 10 # seconds — used for implicit waits and max wait time
viewport:
  width: 1920
  height: 1080

browser_arguments:
  chrome:
    - no-sandbox
    - disable-dev-shm-usage
    - ignore-certificate-errors
    - search-engine-choice-country
  firefox:
    - acceptInsecureCerts
    - no-sandbox