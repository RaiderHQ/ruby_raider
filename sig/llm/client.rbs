# Type definitions for Llm::Client
module Llm
  module Client
    MAX_RETRIES: Integer
    BASE_DELAY: Integer

    def self?.complete: (String prompt, ?String? system_prompt) -> String?
    def self?.available?: () -> bool
    def self?.status: () -> Hash[Symbol, untyped]

    private

    def self?.build_provider: () -> Llm::Provider?
  end
end
